# ─────────────────────────────────────────────────────────────
# Red-Teaming Framework for LLM Safety — Environment Variables
# ─────────────────────────────────────────────────────────────

# Required: OpenAI API key for both the target LLM and DeepTeam's
# attack simulation / evaluation judges
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override the target model (default: gpt-4o-mini)
TARGET_MODEL=gpt-4o-mini

# Optional: Override the simulator model used by DeepTeam
# to generate adversarial prompts (default: gpt-4o-mini)
SIMULATOR_MODEL=gpt-4o-mini

# Optional: Override the evaluation judge model (default: gpt-4o)
EVALUATION_MODEL=gpt-4o

# Optional: Number of attacks per vulnerability sub-type (default: 3)
ATTACKS_PER_VULNERABILITY=3

# Optional: Max concurrent coroutines for async red-teaming (default: 5)
MAX_CONCURRENT=5
